df %>%
mutate(fields = if_else(str_detect(tolower(department), "Political|Government")),
"Political Science", "Others") %>%
group_by(institution, fields) %>%
summarize(n = n()) %>%
mutate(institution = fct_reorder(institution, n)) %>%
ggplot(aes(x = institution, y = n, fill = fields)) +
geom_col() +
coord_flip() +
theme_clean() +
labs(x = "", y = "Count",
title = "Coauthor Institutions Count",
subtitle = "Including the coauthors of published and working papers")
