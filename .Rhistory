as_data_frame()
df <- read.csv("coauthors_jae_yeon_kim.csv") %>%
as_tibble()
df %>%
group_by(institution, department) %>%
summarize(n = n()) %>%
mutate(institution = fct_reorder(institution, n)) %>%
ggplot(aes(x = institution, y = n)) +
geom_col() +
coord_flip() +
theme_clean() +
labs(x = "", y = "Count",
title = "Coauthor Institutions Count",
subtitle = "Including the coauthors of published and working papers"
)
df %>%
group_by(institution, department) %>%
